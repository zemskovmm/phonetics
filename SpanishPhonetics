</tr>
<tr>
<td><strong>qu</strong> before <strong>e/i</strong></td>
<td><code>/k/</code></td>
<td><strong>queso</strong> <code>/ˈkeso/</code>, <strong>quince</strong> <code>/ˈkinθe/</code></td>
</tr>
<tr>
<td><strong>g</strong> before <strong>a/o/u</strong></td>
