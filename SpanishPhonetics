</tr>
<tr>
<td><strong>g</strong> before <strong>e/i</strong></td>
<td><code>/x/</code></td>
<td><strong>gente</strong> <code>/ˈxente/</code>, <strong>girar</strong> <code>/xiˈɾaɾ/</code></td>
</tr>
<tr>
<td><strong>gu</strong> before <strong>e/i</strong></td>
